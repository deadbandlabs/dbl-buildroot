# U-Boot config fragment for MYD-YF135 SPI-NAND via QSPI
#
# The stm32mp13 base defconfig targets the DK evaluation boards which boot
# from SD/eMMC and do not enable the QSPI or SPI-NAND drivers. This fragment
# adds what is needed so U-Boot can access the Micron MT29F2G01ABAGDWB SPI-NAND
# and expose it as the "spi-nand0" MTD device in the DFU alt info (used by
# STM32CubeProgrammer via the flashlayout.tsv IP=spi-nand0 entries).

# SPI framework: DM_SPI is required by both STM32_QSPI and MTD_SPI_NAND
CONFIG_SPI=y
CONFIG_DM_SPI=y
CONFIG_SPI_MEM=y

# STM32 QSPI controller
CONFIG_STM32_QSPI=y

# SPI-NAND MTD stupport (includes vendor drivers)
# Depends on DM_MTD (already set by stm32mp13 defconfig) and DM_SPI (above)
CONFIG_MTD_SPI_NAND=y
CONFIG_MTD_NAND=y
CONFIG_CMD_NAND=y

# Immediate autoboot with no prompt (see debug fragment for options)
CONFIG_BOOTDELAY=-2

# Refresh IWDG2 (started by TF-A) so U-Boot doesn't reset at idle.
# WDT is the parent DM symbol; WDT_STM32MP won't enable without it.
# WATCHDOG enables the cyclic refresh task; without it the driver starts
# the hardware but never services it, resulting in a reset while flashing images
CONFIG_WDT=y
CONFIG_WDT_STM32MP=y
CONFIG_WATCHDOG=y
CONFIG_WATCHDOG_AUTOSTART=y

# WDT command: lets us inspect/stop the watchdog from the console.
CONFIG_CMD_WDT=y

# DFU buffer: 1 MB per drain (8 erase-blocks). Smaller chunks reduce
# USB blackout during the blocking SPI-NAND erase phase.
CONFIG_SYS_DFU_DATA_BUF_SIZE=0x100000
CONFIG_SYS_DFU_MAX_FILE_SIZE=0x2400000

# Enable standalone `dfu` command so we can flash NAND from U-Boot console
# with dfu-util, bypassing CubeProgrammer protocol issues on large files.
CONFIG_CMD_DFU=y

# zstd decompression: required to read zstd-compressed UBIFS file data
CONFIG_ZSTD=y
