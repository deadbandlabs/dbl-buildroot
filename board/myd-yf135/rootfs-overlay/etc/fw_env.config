#
# U-Boot env in UBI (CONFIG_ENV_IS_IN_UBI=y, redundant).
# Matches uboot.config: CONFIG_ENV_SIZE=0x4000, CONFIG_ENV_UBI_PART="UBI",
# volumes env-a (vol 5) + env-b (vol 6) per ubinize.cfg.
#
# Columns: <device>  <offset>  <env-size>  <sector-size>
# sector-size = UBI LEB = 0x1f000 (126976 B).
/dev/ubi0_5   0x0   0x4000   0x1f000
/dev/ubi0_6   0x0   0x4000   0x1f000
