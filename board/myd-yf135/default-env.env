# SPDX-License-Identifier: GPL-2.0-or-later
# Copyright 2026 Deadband Inc.
#
# U-Boot default env for MYD-YF135
#
# Compiled into uboot.env by mkenvimage (-r for redundant flag byte).
# Pre-loaded into UBI volumes env-a and env-b by ubinize (see ubinize.cfg)
#
# Boot chain: A -> B -> factory -> DFU fallback
# Slot retry counters (BOOT_<slot>_LEFT) decrement before each attempt
# Userspace `rauc-mark-good` (run after successful boot) resets the counter.
# Factory image has no counter, if factory also fails to boot, U-Boot goes to USB DFU
# as the unconditional last resort.
#
# U-Boot sets `ver` from CONFIG_VERSION_VARIABLE on every boot
# Linux can then compare if the expected FIP or a fallback was used by
# comparing ver via fw_printenv against /etc/firmware/expected-bl33-version

bootcmd=if test ${boot_device} = serial || test ${boot_device} = usb; then stm32prog ${boot_device} ${boot_instance}; else run try_boot; fi

# RAUC u-boot integration variables
BOOT_ORDER=A B
BOOT_A_LEFT=3
BOOT_B_LEFT=3

# Per-slot boot recipes
boot_A=ubifsmount ubi0:rootfs_a; ubifsload 0xc2000040 /boot/uImage; ubifsload 0xc1000000 /boot/stm32mp135d-myd-yf135.dtb; setenv bootargs root=ubi0:rootfs_a rootfstype=ubifs ubi.mtd=UBI ro rauc.slot=A console=ttySTM0,115200 earlycon; bootm 0xc2000040 - 0xc1000000
boot_B=ubifsmount ubi0:rootfs_b; ubifsload 0xc2000040 /boot/uImage; ubifsload 0xc1000000 /boot/stm32mp135d-myd-yf135.dtb; setenv bootargs root=ubi0:rootfs_b rootfstype=ubifs ubi.mtd=UBI ro rauc.slot=B console=ttySTM0,115200 earlycon; bootm 0xc2000040 - 0xc1000000
boot_factory=ubifsmount ubi0:rootfs_factory; ubifsload 0xc2000040 /boot/uImage; ubifsload 0xc1000000 /boot/stm32mp135d-myd-yf135.dtb; setenv bootargs root=ubi0:rootfs_factory rootfstype=ubifs ubi.mtd=UBI ro rauc.slot=factory console=ttySTM0,115200 earlycon; bootm 0xc2000040 - 0xc1000000

# Per-slot try wrappers: decrement counter, persist, run boot recipe.
# `bootm` does not return on success; if it returns we fall through.
try_A=if test ${BOOT_A_LEFT} -gt 0; then setexpr BOOT_A_LEFT ${BOOT_A_LEFT} - 1; saveenv; echo "Booting slot A (attempts left: ${BOOT_A_LEFT})"; run boot_A; echo "Slot A returned (boot failed)"; fi
try_B=if test ${BOOT_B_LEFT} -gt 0; then setexpr BOOT_B_LEFT ${BOOT_B_LEFT} - 1; saveenv; echo "Booting slot B (attempts left: ${BOOT_B_LEFT})"; run boot_B; echo "Slot B returned (boot failed)"; fi

# Top-level boot script (CONFIG_BOOTCOMMAND="[...] run try_boot").
# Iterate starting with slot marked active, falling back to factory then finally USB DFU
try_boot=ubi part UBI; for slot in ${BOOT_ORDER}; do run try_${slot}; done; echo "BOOT_ORDER exhausted, falling back to factory"; run boot_factory; echo "Factory rootfs failed, dropping to DFU"; stm32prog usb 0
